# Streamlit Cloud → app settings → Secrets → paste this with your real key.
# Locally:        copy this to .streamlit/secrets.toml and fill in.
# Do NOT commit a real key to git.

ANTHROPIC_API_KEY = "sk-ant-paste-your-key-here"

# Optional — enables automatic pull from Navy Recruiting Sheet 2.0 (Admin tab
# falls back to manual xlsx upload if this isn't set). Setup:
#   1. console.cloud.google.com -> new (or existing) project -> APIs & Services
#      -> Library -> enable "Google Drive API"
#   2. APIs & Services -> Credentials -> Create Credentials -> Service Account
#      -> create a key for it (JSON) -> download the JSON file
#   3. Open Recruiting Sheet 2.0 -> Share -> paste the service account's
#      email (looks like xxx@xxx.iam.gserviceaccount.com) -> Viewer is enough
#   4. Copy the fields below straight out of the downloaded JSON
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "your-service-account@your-project-id.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
