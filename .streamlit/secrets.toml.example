# Streamlit Cloud → app settings → Secrets → paste this with your real key.
# Locally:        copy this to .streamlit/secrets.toml and fill in.
# Do NOT commit a real key to git.

ANTHROPIC_API_KEY = "sk-ant-paste-your-key-here"

# Recruiting Sheet 2.0 sync (Admin tab) needs no secret here — it pulls via
# Drive's public export endpoint since the sheet is shared "anyone with the
# link can view" (intentional, confirmed with Chris 2026-06-30). See
# sheet_sync.py for why, and what would need to change if that sharing
# setting is ever tightened (e.g. for write-back access later).
