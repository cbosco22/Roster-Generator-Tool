# Streamlit Cloud → app settings → Secrets → paste this with your real key.
# Locally:        copy this to .streamlit/secrets.toml and fill in.
# Do NOT commit a real key to git.

ANTHROPIC_API_KEY = "sk-ant-paste-your-key-here"

# Recruiting Sheet 2.0 READ sync (Admin tab) needs no secret here — it
# pulls via Drive's public export endpoint since the sheet is shared
# "anyone with the link can view" (intentional, confirmed with Chris
# 2026-06-30). See sheet_sync.py for why.

# Recruiting Sheet 2.0 WRITE access (post-event auto-update, player add
# tools) needs these two — from the Apps Script web app Chris deploys
# himself (see apps_script/README.md for exact steps; not a GCP credential,
# not subject to the org policy that blocked the service-account approach).
sheet_write_url = "https://script.google.com/macros/s/PASTE-DEPLOYMENT-ID/exec"
sheet_write_token = "paste-the-same-long-random-secret-set-in-Code.gs"
